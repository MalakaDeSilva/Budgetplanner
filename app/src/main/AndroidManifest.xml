<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    package="com.bb.budgetplanner">

    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme"
        tools:ignore="GoogleAppIndexingWarning">
        <activity android:name=".MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".HistoryandReports"
            android:parentActivityName=".MainActivity" />
        <activity
            android:name=".Expenses"
            android:parentActivityName=".MainActivity" />
        <activity
            android:name=".Update_income"
            android:parentActivityName=".View_income" />
        <activity
            android:name=".View_income"
            android:parentActivityName=".Income" />
        <activity
            android:name=".Income"
            android:parentActivityName=".MainActivity" />
        <activity
            android:name=".Add_income"
            android:parentActivityName=".Income" />

        <activity android:name=".Spending_Limit"
            android:parentActivityName=".MainActivity" />
    </application>

</manifest>